# Database — Neon PostgreSQL (or any postgresql connection string)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Lemon Squeezy — only products listed in your LS store appear on the storefront
LEMONSQUEEZY_API_KEY=your_lemon_squeezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id

# Optional: override the PKR conversion rate (default 280)
# NEXT_PUBLIC_PKR_RATE=280

# Optional: JWT secret for auth (defaults to a dev secret)
# JWT_SECRET=your_jwt_secret

# WooCommerce integration (admin panel → sync products/orders)
# Get keys at: WooCommerce → Settings → Advanced → REST API
# WOOCOMMERCE_STORE_URL=https://shop.playbeat.live
# WOOCOMMERCE_CONSUMER_KEY=ck_xxxxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxx

# WordPress CMS integration (admin panel → manage posts/pages)
# Generate app password at: WordPress → Users → Profile → Application Passwords
# WORDPRESS_API_URL=https://playbeat.live/wp-json/wp/v2
# WORDPRESS_USERNAME=your_wp_username
# WORDPRESS_APP_PASSWORD=your_app_password
